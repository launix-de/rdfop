@prefix rdfop: <https://launix.de/rdfop/schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

################################################################
# Tab + TabGroup
################################################################

# --- Tab ---
rdfop:Tab a rdfop:EntityType .
rdfop:tabLabel a rdf:Property ; rdfs:domain rdfop:Tab ; rdfs:range rdfs:Literal .
rdfop:Tab rdfop:onChildRemoved """
PARAMETER ?removedChild "child"
SELECT ?gone WHERE { ?id rdfop:children ?removedChild }
BEGIN
  DELETE { ?id rdfop:children ?removedChild }
END
SELECT ?tabgroup WHERE { ?tabgroup rdfop:children ?id }
BEGIN
  DELETE { ?tabgroup rdfop:children ?id }
  SELECT ?p, ?o WHERE { ?id ?p ?o } BEGIN DELETE { ?id ?p ?o } END
  CALL rdfop_action("onChildRemoved", ?tabgroup, "child", ?id)
END
""" .
rdfop:Tab rdfop:initTemplate """$ID <https://launix.de/rdfop/schema#tabLabel> "New Tab" .
$ID <https://launix.de/rdfop/schema#children> _:child .
_:child a <https://launix.de/rdfop/schema#ComponentSelector> .
""" .

# TabGroup components
rdfop:TabGroup rdfop:onChildRemoved """
PARAMETER ?removedChild "child"
SELECT ?tab WHERE { ?id rdfop:children ?tab }
BEGIN
ELSE
  SELECT ?parent WHERE { ?parent rdfop:selectedNode ?id }
  BEGIN
    DELETE { ?parent rdfop:selectedNode ?id }
    DELETE { ?parent rdfop:children ?id }
    SELECT ?p, ?o WHERE { ?id ?p ?o } BEGIN DELETE { ?id ?p ?o } END
    CALL rdfop_action("onChildRemoved", ?parent, "child", ?id)
  END
END
""" .
rdfop:TabGroup rdfop:view rdfop:TabGroup_view .

rdfop:TabGroup_view a rdfop:EditorComponent ;
  rdfop:js """
window.rdfopTabsSchema = 'https://launix.de/rdfop/schema#';
window.rdfopTabsReadDraggedTabId = function(e) {
  if (!e || !e.dataTransfer) return null;
  return e.dataTransfer.getData('application/x-rdfop-tab-id') || null;
};
window.rdfopTabsReadDraggedTabGroup = function(e) {
  if (!e || !e.dataTransfer) return null;
  return e.dataTransfer.getData('application/x-rdfop-tab-group') || null;
};
window.rdfopTabsCanReorderInto = function(e, tabs) {
  if (!e || !tabs) return false;
  var dragTabId = rdfopTabsReadDraggedTabId(e);
  var dragGroupId = rdfopTabsReadDraggedTabGroup(e);
  var dropGroupId = JSON.parse(tabs.dataset.rdfopParams || '{}').id;
  return !!(dragTabId && dragGroupId && dropGroupId && dragGroupId === dropGroupId);
};
window.rdfopTabsSetLabel = async function(tabId, nextLabel) {
  if (!tabId || !nextLabel) return;
  await rdfopSave(
    '<' + tabId + '> <https://launix.de/rdfop/schema#tabLabel> "New Tab" .',
    '<' + tabId + '> <https://launix.de/rdfop/schema#tabLabel> ' + JSON.stringify(nextLabel) + ' .'
  );
};
window.rdfopTabsGuessLabel = async function(contentId) {
  if (!contentId) return null;
  var labels = await _rdfopQuery('SELECT ?label WHERE { <' + contentId + '> a ?type . ?type <http://www.w3.org/2000/01/rdf-schema#label> ?label }');
  return labels.length && labels[0]['?label'] ? labels[0]['?label'] : null;
};
window.rdfopTabsBindNewTabContent = async function(newTabId, contentId) {
  var children = await _rdfopQuery('SELECT ?c WHERE { <' + newTabId + '> <https://launix.de/rdfop/schema#children> ?c }');
  if (!children.length) return null;
  var autoSelectorId = children[0]['?c'];
  var types = await _rdfopQuery('SELECT ?t WHERE { <' + contentId + '> a ?t }');
  var isSelector = types.some(function(row) {
    return row['?t'] === window.rdfopTabsSchema + 'ComponentSelector';
  });
  if (isSelector) {
    await rdfopSave(
      '<' + newTabId + '> <https://launix.de/rdfop/schema#children> ' + rdfopSid(autoSelectorId) + ' .\n' +
      rdfopSid(autoSelectorId) + ' a <https://launix.de/rdfop/schema#ComponentSelector> .',
      '<' + newTabId + '> <https://launix.de/rdfop/schema#children> ' + rdfopSid(contentId) + ' .'
    );
    return {selectorId: contentId, contentId: contentId};
  }
  await rdfopSave(
    null,
    rdfopSid(autoSelectorId) + ' <https://launix.de/rdfop/schema#selectedNode> ' + rdfopSid(contentId) + ' .\n' +
    rdfopSid(autoSelectorId) + ' <https://launix.de/rdfop/schema#children> ' + rdfopSid(contentId) + ' .\n'
  );
  return {selectorId: autoSelectorId, contentId: contentId};
};
window.rdfopTabsRefreshAfterSourceCleanup = async function(tab) {
  var tabs = tab && tab.closest ? tab.closest('.rdfop-tabs') : null;
  if (tabs && document.contains(tabs)) {
    await rdfopSwap(tabs, 'view');
    return;
  }
  await rdfopRefreshCanvas();
};
window.rdfopTabsHandleSameWindowDrop = async function(tab, result) {
  if (!tab || (result && result.reordered)) return;
  var tabId = tab.dataset.tabId;
  var childId = tab.dataset.childId;
  var contentId = tab.dataset.contentId || childId;
  if (!tabId || !childId || !contentId) return;
  if (result && result.leaveSourcePalette && contentId !== childId) {
    await rdfopSelectorAssign(childId, null, contentId);
    await rdfopTabsRefreshAfterSourceCleanup(tab);
    return;
  }
  if (contentId === childId) {
    await fetch('/onChildRemoved/' + encodeURIComponent(tabId) + '?child=' + encodeURIComponent(childId));
  } else {
    await rdfopSelectorRemoveContent(childId, contentId);
  }
  await rdfopTabsRefreshAfterSourceCleanup(tab);
};
window.rdfopTabsPersistOrder = async function(tabs, orderedIds) {
  if (!tabs || !orderedIds || !orderedIds.length) return;
  var allTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
  var base = Date.now();
  for (var i = 0; i < orderedIds.length; i++) {
    var id = orderedIds[i];
    var sid = rdfopSid(id);
    var tabEl = allTabs.find(function(t) { return t.dataset.tabId === id; });
    var oldOrd = tabEl ? tabEl.dataset.tabOrder : null;
    if (!oldOrd) {
      var rows = await _rdfopQuery('SELECT ?o WHERE { <' + id + '> <https://launix.de/rdfop/schema#order> ?o }');
      oldOrd = rows.length && rows[0]['?o'] ? rows[0]['?o'] : null;
    }
    var newOrd = String(base + i);
    if (oldOrd !== newOrd) {
      await rdfopSave(
        oldOrd ? (sid + ' <https://launix.de/rdfop/schema#order> ' + JSON.stringify(oldOrd) + ' .') : null,
        sid + ' <https://launix.de/rdfop/schema#order> ' + JSON.stringify(newOrd) + ' .'
      );
    }
  }
};
window.rdfopTabsAdd = async function(btn) {
  var tabs = btn.closest('.rdfop-c');
  if (!tabs) return;
  var tabGroupP = JSON.parse(tabs.dataset.rdfopParams || '{}');
  var resp = await fetch('/rdfop-create', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'parent=' + encodeURIComponent(tabGroupP.id) + '&type=https%3A%2F%2Flaunix.de%2Frdfop%2Fschema%23Tab'
  });
  if (!resp.ok) return;
  var newTabId = (await resp.text()).trim();
  var orderedIds = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab')).map(function(tab) {
    return tab.dataset.tabId;
  });
  orderedIds.push(newTabId);
  await rdfopTabsPersistOrder(tabs, orderedIds);
  await rdfopSwap(tabs, 'view');
  setTimeout(function() {
    var tab = document.querySelector('.rdfop-tabs__tab[data-tab-id="' + newTabId + '"]');
    if (tab) rdfopTabsSwitch(tab);
  }, 0);
};
window.rdfopTabsDirection = function(bar) {
  var tabs = bar.closest('.rdfop-c');
  var p = JSON.parse(tabs.dataset.rdfopParams || '{}');
  var dirs = {top:'\u2B06 Tabs top',bottom:'\u2B07 Tabs bottom',left:'\u2B05 Tabs left',right:'\u2B95 Tabs right',leftRotated:'\u2934 Tabs left (rotated)',rightRotated:'\u2935 Tabs right (rotated)'};
  var menu = document.createElement('div');
  menu.className = 'rdfop-dir-menu';
  menu.style.cssText = 'position:fixed;z-index:9999;background:var(--panel);border:1px solid var(--ring);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.15);padding:4px 0';
  Object.keys(dirs).forEach(function(d) {
    var item = document.createElement('div');
    item.textContent = dirs[d];
    item.style.cssText = 'padding:6px 16px;cursor:pointer;white-space:nowrap';
    item.onmouseover = function(){item.style.background='#f1f5f9'};
    item.onmouseout = function(){item.style.background=''};
    item.onclick = async function() {
      var sid = rdfopSid(p.id);
      var oldDir = tabs.dataset.rdfopDir || 'top';
      await rdfopSave(
        sid + ' <https://launix.de/rdfop/schema#tabDirection> ' + JSON.stringify(oldDir) + ' .',
        sid + ' <https://launix.de/rdfop/schema#tabDirection> ' + JSON.stringify(d) + ' .'
      );
      menu.remove();
      var activeTabId = (tabs.querySelector('.rdfop-tabs__tab--active') || {}).dataset;
      activeTabId = activeTabId ? activeTabId.tabId : null;
      await rdfopSwap(tabs, 'view');
      if (activeTabId) {
        var t = document.querySelector('.rdfop-tabs__tab[data-tab-id="' + activeTabId + '"]');
        if (t) t.click();
      }
    };
    menu.appendChild(item);
  });
  document.body.appendChild(menu);
  var r = bar.getBoundingClientRect();
  var mw = menu.offsetWidth;
  var mh = menu.offsetHeight;
  var vw = window.innerWidth;
  var vh = window.innerHeight;
  if (r.width > r.height) {
    menu.style.left = Math.min(r.left, vw - mw) + 'px';
    menu.style.top = (r.bottom + mh > vh ? r.top - mh : r.bottom) + 'px';
  } else {
    menu.style.left = (r.right + mw > vw ? r.left - mw : r.right) + 'px';
    menu.style.top = Math.min(r.top, vh - mh) + 'px';
  }
  var close = function(e){if(!menu.contains(e.target)){menu.remove();document.removeEventListener('click',close)}};
  setTimeout(function(){document.addEventListener('click',close)},0);
};
window.rdfopTabClose = async function(tabEl) {
  var tabName = tabEl.querySelector('.rdfop-textedit') ? tabEl.querySelector('.rdfop-textedit').textContent.trim() : 'tab';
  if (!confirm('Delete tab "' + tabName + '"?')) return;
  var tabId = tabEl.dataset.tabId;
  var tabs = tabEl.closest('.rdfop-c');
  var panel = tabs.querySelector(':scope > .rdfop-tabs__content > .rdfop-tabs__panel[data-tab-id="' + tabId + '"]');
  var childId = panel ? panel.dataset.childId : null;
  var wasActive = tabEl.classList.contains('rdfop-tabs__tab--active');
  var allTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
  var idx = allTabs.indexOf(tabEl);
  var nextIdx = idx < allTabs.length - 1 ? idx + 1 : idx - 1;
  var nextTabId = nextIdx >= 0 ? allTabs[nextIdx].dataset.tabId : null;
  var url = '/onChildRemoved/' + encodeURIComponent(tabId);
  if (childId) {
    await fetch('/rdfop-delete', {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: 'id=' + encodeURIComponent(childId)
    });
  }
  if (childId) url += '?child=' + encodeURIComponent(childId);
  await fetch(url);
  if (allTabs.length <= 1) {
    tabs.dispatchEvent(new CustomEvent('rdfop:layoutChildRemoved', {bubbles: true}));
    return;
  }
  await rdfopSwap(tabs, 'view');
  if (wasActive) {
    setTimeout(function() {
      var t = nextTabId ? document.querySelector('.rdfop-tabs__tab[data-tab-id="' + nextTabId + '"]') : document.querySelector('.rdfop-tabs__tab');
        if (t) rdfopTabsSwitch(t);
    }, 0);
  }
};
window._rdfopActiveTabs = JSON.parse(localStorage.getItem('rdfop-active-tabs') || '{}');
window.rdfopTabsSwitch = function(t) {
  var tabs = t.closest('.rdfop-tabs');
  tabs.querySelectorAll(':scope > .rdfop-tabs__bar > .rdfop-tabs__tab').forEach(function(x){x.classList.remove('rdfop-tabs__tab--active')});
  tabs.querySelectorAll(':scope > .rdfop-tabs__content > .rdfop-tabs__panel').forEach(function(x){x.classList.remove('rdfop-tabs__panel--active')});
  t.classList.add('rdfop-tabs__tab--active');
  var p = tabs.querySelector(':scope > .rdfop-tabs__content > .rdfop-tabs__panel[data-tab-id="' + t.dataset.tabId + '"]');
  if (p) p.classList.add('rdfop-tabs__panel--active');
  var gid = JSON.parse(tabs.dataset.rdfopParams || '{}').id;
  if (gid) {
    _rdfopActiveTabs[gid] = t.dataset.tabId;
    localStorage.setItem('rdfop-active-tabs', JSON.stringify(_rdfopActiveTabs));
  }
};
window.rdfopTabsInit = function(el) {
  var tabgroups = el.querySelectorAll ? Array.from(el.querySelectorAll('.rdfop-tabs')) : Array.from(document.querySelectorAll('.rdfop-tabs'));
  if (el.classList && el.classList.contains('rdfop-tabs')) tabgroups.unshift(el);
  tabgroups.forEach(function(t) {
    t.querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after,.rdfop-tabs__tab--dragging').forEach(function(d){
      d.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after','rdfop-tabs__tab--dragging');
    });
    t.querySelectorAll('.rdfop-tabs__bar--drop-target').forEach(function(d){ d.classList.remove('rdfop-tabs__bar--drop-target'); });
    if (t.querySelector(':scope > .rdfop-tabs__bar > .rdfop-tabs__tab--active')) return;
    var gid = JSON.parse(t.dataset.rdfopParams || '{}').id;
    var saved = gid ? _rdfopActiveTabs[gid] : null;
    var tab = saved ? t.querySelector(':scope > .rdfop-tabs__bar > .rdfop-tabs__tab[data-tab-id="' + saved + '"]') : null;
    if (!tab) tab = t.querySelector(':scope > .rdfop-tabs__bar > .rdfop-tabs__tab');
    if (tab) rdfopTabsSwitch(tab);
  });
};
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ rdfopTabsInit(document); });
else rdfopTabsInit(document);
document.addEventListener('rdfop:layoutChildRemoved', function(e) {
  if (e.target.closest('.rdfop-split')) return;
  var tabs = e.target.closest('.rdfop-tabs');
  if (tabs) rdfopSwap(tabs, 'view');
});
window.rdfopTabsEnableExternalHover = function() {
  document.querySelectorAll('.rdfop-tabs__tab').forEach(function(tab) {
    tab.addEventListener('dragover', rdfopTabsHoverDuringExternalDrag);
  });
};
window.rdfopTabsDisableExternalHover = function() {
  document.querySelectorAll('.rdfop-tabs__tab').forEach(function(tab) {
    tab.removeEventListener('dragover', rdfopTabsHoverDuringExternalDrag);
    clearTimeout(tab._rdfopHoverTimer);
    tab._rdfopHoverTimer = null;
  });
};
window.rdfopTabsHoverDuringExternalDrag = function(e) {
  var tab = e.currentTarget;
  if (!tab._rdfopHoverTimer) tab._rdfopHoverTimer = setTimeout(function(){
    tab._rdfopHoverTimer = null;
    rdfopTabsSwitch(tab);
  }, 800);
};
document.addEventListener('rdfop:externalDragStart', function() {
  rdfopTabsEnableExternalHover();
});
document.addEventListener('rdfop:externalDragEnd', function() {
  document.querySelectorAll('.rdfop-tabs__bar').forEach(function(bar) {
    bar.classList.remove('rdfop-tabs__bar--drop-target');
  });
  document.querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(tab) {
    tab.classList.remove('rdfop-tabs__tab--dragover-before', 'rdfop-tabs__tab--dragover-after');
  });
  rdfopTabsDisableExternalHover();
});
window.rdfopTabsBarDropPosition = function(e, bar) {
  var allTabs = Array.from(bar.querySelectorAll('.rdfop-tabs__tab'));
  if (!allTabs.length) return {after: null};
  var tabs = bar.closest('.rdfop-c');
  var isVert = tabs && (tabs.classList.contains('rdfop-tabs--left') || tabs.classList.contains('rdfop-tabs--right') || tabs.classList.contains('rdfop-tabs--leftRotated') || tabs.classList.contains('rdfop-tabs--rightRotated'));
  for (var i = 0; i < allTabs.length; i++) {
    var rect = allTabs[i].getBoundingClientRect();
    var mid = isVert ? (rect.top + rect.height / 2) : (rect.left + rect.width / 2);
    var pos = isVert ? e.clientY : e.clientX;
    if (pos < mid) return {before: allTabs[i]};
  }
  return {after: allTabs[allTabs.length - 1]};
};
window.rdfopTabsBarDragOver = function(e, bar) {
  if (rdfopTabsCanReorderInto(e, bar.closest('.rdfop-c'))) return;
  if (rdfopDragReadKind(e) !== 'component') return;
  e.preventDefault();
  e.stopPropagation();
  bar.classList.remove('rdfop-tabs__bar--drop-target');
  bar.querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){
    t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after');
  });
  var pos = rdfopTabsBarDropPosition(e, bar);
  if (pos.before) pos.before.classList.add('rdfop-tabs__tab--dragover-before');
  else if (pos.after) pos.after.classList.add('rdfop-tabs__tab--dragover-after');
  else bar.classList.add('rdfop-tabs__bar--drop-target');
};
window.rdfopTabsBarDrop = async function(e, bar) {
  e.preventDefault();
  e.stopPropagation();
  bar.classList.remove('rdfop-tabs__bar--drop-target');
  bar.querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){
    t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after');
  });
  var tabs = bar.closest('.rdfop-c');
  if (rdfopTabsCanReorderInto(e, tabs)) {
    rdfopDragMarkDropped();
    var dragTabId = rdfopTabsReadDraggedTabId(e);
    if (!dragTabId) return;
    var allExistingTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
    var orderedIds = allExistingTabs.map(function(tab) { return tab.dataset.tabId; }).filter(function(id) { return id !== dragTabId; });
    orderedIds.push(dragTabId);
    await rdfopTabsPersistOrder(tabs, orderedIds);
    await rdfopSwap(tabs, 'view');
    setTimeout(function() {
      var active = document.querySelector('.rdfop-tabs__tab[data-tab-id="' + dragTabId + '"]');
      if (active) rdfopTabsSwitch(active);
    }, 0);
    return;
  }
  if (rdfopDragReadKind(e) !== 'component') return;
  var uri = rdfopDragReadUri(e);
  var contentId = uri ? rdfopDragReadViewIdFromUri(uri) : null;
  if (!contentId) return;
  rdfopDragMarkDropped(uri);
  var pos = rdfopTabsBarDropPosition(e, bar);
  var tabGroupP = JSON.parse(tabs.dataset.rdfopParams || '{}');
  var resp = await fetch('/rdfop-create', {
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'parent=' + encodeURIComponent(tabGroupP.id) + '&type=https%3A%2F%2Flaunix.de%2Frdfop%2Fschema%23Tab'
  });
  if (!resp.ok) return;
  var newTabId = (await resp.text()).trim();
  var embedded = await rdfopTabsBindNewTabContent(newTabId, contentId);
  if (!embedded) return;
  var sourceLabel = e.dataTransfer ? (e.dataTransfer.getData('application/x-rdfop-tab-label') || '').trim() : '';
  var nextLabel = sourceLabel || await rdfopTabsGuessLabel(embedded.contentId);
  if (nextLabel) {
    await rdfopTabsSetLabel(newTabId, nextLabel);
  }
  var orderedIds = Array.from(bar.querySelectorAll('.rdfop-tabs__tab')).map(function(tab) {
    return tab.dataset.tabId;
  });
  if (pos.before) {
    orderedIds.splice(Math.max(0, orderedIds.indexOf(pos.before.dataset.tabId)), 0, newTabId);
  } else if (pos.after) {
    orderedIds.splice(orderedIds.indexOf(pos.after.dataset.tabId) + 1, 0, newTabId);
  } else {
    orderedIds.push(newTabId);
  }
  await rdfopTabsPersistOrder(tabs, orderedIds);
  if (!rdfopDragHasLocalSource(uri)) await rdfopDragCleanupSource(e, {});
  await rdfopDragFinish(uri, {});
  await rdfopSwap(tabs, 'view');
  setTimeout(function() {
    var t = document.querySelector('.rdfop-tabs__tab[data-tab-id="' + newTabId + '"]');
    if (t) rdfopTabsSwitch(t);
  }, 0);
};
window.rdfopTabsReorderStart = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (!tab) return;
  var tabs = tab.closest('.rdfop-tabs');
  var groupId = tabs ? JSON.parse(tabs.dataset.rdfopParams || '{}').id : null;
  rdfopDragStartLink(e, tab, {
    kind: 'component',
    sourcePayload: {
      kind: 'tab',
      tabId: tab.dataset.tabId || '',
      childId: tab.dataset.childId || '',
      contentId: tab.dataset.contentId || tab.dataset.childId || ''
    },
    handleSameWindowDrop: async function(result) {
      await rdfopTabsHandleSameWindowDrop(tab, result || {});
    }
  });
  if (!e.dataTransfer) return;
  e.dataTransfer.setData('application/x-rdfop-tab-id', tab.dataset.tabId || '');
  e.dataTransfer.setData('application/x-rdfop-tab-group', groupId || '');
  var label = tab.querySelector('.rdfop-textedit');
  e.dataTransfer.setData('application/x-rdfop-tab-label', label ? label.textContent.trim() : '');
  tab.classList.add('rdfop-tabs__tab--dragging');
};
window.rdfopTabsReorderOver = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (!tab) return;
  var tabs = tab.closest('.rdfop-c');
  if (!rdfopTabsCanReorderInto(e, tabs)) {
    if (rdfopDragReadKind(e) !== 'component') return;
    var bar = tab.closest('.rdfop-tabs__bar');
    if (bar) rdfopTabsBarDragOver(e, bar);
    return;
  }
  e.preventDefault();
  e.stopPropagation();
  tab.classList.remove('rdfop-tabs__tab--dragover-before', 'rdfop-tabs__tab--dragover-after');
  var rect = tab.getBoundingClientRect();
  var isVert = tabs.classList.contains('rdfop-tabs--left') || tabs.classList.contains('rdfop-tabs--right') || tabs.classList.contains('rdfop-tabs--leftRotated') || tabs.classList.contains('rdfop-tabs--rightRotated');
  var mid = isVert ? (rect.top + rect.height / 2) : (rect.left + rect.width / 2);
  var pos = isVert ? e.clientY : e.clientX;
  tab.classList.add(pos > mid ? 'rdfop-tabs__tab--dragover-after' : 'rdfop-tabs__tab--dragover-before');
};
window.rdfopTabsReorderLeave = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (tab) tab.classList.remove('rdfop-tabs__tab--dragover-before', 'rdfop-tabs__tab--dragover-after');
};
window.rdfopTabsReorderDrop = async function(e) {
  var targetTab = e.target.closest('.rdfop-tabs__tab');
  if (!targetTab) return;
  var tabs = targetTab.closest('.rdfop-c');
  if (!rdfopTabsCanReorderInto(e, tabs)) {
    if (rdfopDragReadKind(e) !== 'component') return;
    var bar = targetTab.closest('.rdfop-tabs__bar');
    if (bar) await rdfopTabsBarDrop(e, bar);
    return;
  }
  e.preventDefault();
  e.stopPropagation();
  rdfopDragMarkDropped();
  tabs.querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){
    t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after');
  });
  var dragId = rdfopTabsReadDraggedTabId(e);
  var dropId = targetTab.dataset.tabId;
  if (!dragId || dragId === dropId) return;
  var allTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
  var rect = targetTab.getBoundingClientRect();
  var isVert = tabs.classList.contains('rdfop-tabs--left') || tabs.classList.contains('rdfop-tabs--right') || tabs.classList.contains('rdfop-tabs--leftRotated') || tabs.classList.contains('rdfop-tabs--rightRotated');
  var mid = isVert ? (rect.top + rect.height / 2) : (rect.left + rect.width / 2);
  var pos = isVert ? e.clientY : e.clientX;
  var insertAfter = pos > mid;
  var ids = allTabs.map(function(t){ return t.dataset.tabId; }).filter(function(id){ return id !== dragId; });
  var dropIdx = ids.indexOf(dropId);
  ids.splice(insertAfter ? dropIdx + 1 : dropIdx, 0, dragId);
  await rdfopTabsPersistOrder(tabs, ids);
  await rdfopSwap(tabs, 'view');
  setTimeout(function() {
    var t = document.querySelector('.rdfop-tabs__tab[data-tab-id="' + dragId + '"]');
    if (t) rdfopTabsSwitch(t);
  }, 0);
};
window.rdfopTabsReorderEnd = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (tab) {
    tab.classList.remove('rdfop-tabs__tab--dragging');
    tab.closest('.rdfop-c').querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){
      t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after');
    });
  }
  if (!window.__rdfopDragSession || !window.__rdfopDragSession.dropped) rdfopDragClear();
};""" ;
  rdfop:css """.rdfop-tabs { display: flex; width: 100%; height: 100%; }
.rdfop-tabs--top, .rdfop-tabs--bottom { flex-direction: column; }
.rdfop-tabs--left, .rdfop-tabs--leftRotated { flex-direction: row; }
.rdfop-tabs--right, .rdfop-tabs--rightRotated { flex-direction: row-reverse; }
.rdfop-tabs--bottom { flex-direction: column-reverse; }
.rdfop-tabs__bar { display: flex; gap: 0; background: #f1f5f9; border-bottom: 1px solid var(--ring); padding: 0 8px; flex-shrink: 0; }
.rdfop-tabs__bar--drop-target { background: rgba(14,165,233,.15); outline: 2px dashed #0ea5e9; }
.rdfop-tabs--left > .rdfop-tabs__bar, .rdfop-tabs--right > .rdfop-tabs__bar { flex-direction: column; width: 180px; border-bottom: none; border-right: 1px solid var(--ring); padding: 8px 0; }
.rdfop-tabs--right > .rdfop-tabs__bar { border-right: none; border-left: 1px solid var(--ring); }
.rdfop-tabs--leftRotated > .rdfop-tabs__bar, .rdfop-tabs--rightRotated > .rdfop-tabs__bar { flex-direction: column; border-bottom: none; border-right: 1px solid var(--ring); padding: 8px 0; }
.rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__tab, .rdfop-tabs--rightRotated > .rdfop-tabs__bar > .rdfop-tabs__tab { writing-mode: vertical-lr; padding: 8px 2px; gap: 2px; display: block; text-align: center; }
.rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__tab { transform: rotate(180deg); }
.rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__dir, .rdfop-tabs--rightRotated > .rdfop-tabs__bar > .rdfop-tabs__dir { writing-mode: horizontal-tb; }
.rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__add, .rdfop-tabs--rightRotated > .rdfop-tabs__bar > .rdfop-tabs__add { writing-mode: horizontal-tb; }
.rdfop-tabs--rightRotated > .rdfop-tabs__bar { border-right: none; border-left: 1px solid var(--ring); }
.rdfop-tabs__tab { padding: 8px 16px; cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; user-select: none; display: flex; align-items: center; gap: 6px; color: inherit; text-decoration: none; position: relative; }
.rdfop-tabs__tab:hover { background: #e2e8f0; }
.rdfop-tabs__tab--active { border-bottom-color: #0ea5e9; font-weight: 600; }
.rdfop-tabs__tab--dragging { opacity: 0.4; }
.rdfop-tabs__tab--dragover-before { box-shadow: 2px 0 0 0 #0ea5e9 inset; }
.rdfop-tabs__tab--dragover-after { box-shadow: -2px 0 0 0 #0ea5e9 inset; }
.rdfop-tabs--left > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-before, .rdfop-tabs--right > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-before, .rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-before, .rdfop-tabs--rightRotated > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-before { box-shadow: 0 2px 0 0 #0ea5e9 inset; }
.rdfop-tabs--left > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-after, .rdfop-tabs--right > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-after, .rdfop-tabs--leftRotated > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-after, .rdfop-tabs--rightRotated > .rdfop-tabs__bar > .rdfop-tabs__tab--dragover-after { box-shadow: 0 -2px 0 0 #0ea5e9 inset; }
.rdfop-tabs__close { display: none; cursor: pointer; font-size: 12px; color: var(--muted); padding: 0 2px; line-height: 1; }
.rdfop-tabs__tab:hover .rdfop-tabs__close { display: inline; }
.rdfop-tabs__close:hover { color: #ef4444; }
.rdfop-tabs__dir { padding: 8px 8px; cursor: pointer; background: none; border: none; font-size: 14px; color: var(--muted); line-height: 1; }
.rdfop-tabs__dir:hover { color: var(--text); }
.rdfop-tabs__add { padding: 8px 12px; cursor: pointer; background: none; border: none; font-size: 16px; color: var(--muted); }
.rdfop-tabs__add:hover { color: var(--text); }
.rdfop-tabs__content { flex: 1; overflow: auto; position: relative; min-height: 0; }
.rdfop-tabs__panel { display: none; width: 100%; height: 100%; }
.rdfop-tabs__panel--active { display: flex; flex-direction: column; }
.rdfop-tabs__panel--active > * { flex: 1; min-height: 0; }""" ;
  # rdfop feature gap: ORDER BY ?ord is only reliable here if the ordered
  # triple is the leading pattern. Start both queries with
  # ?tab rdfop:order ?ord until the planner can reorder joins itself.
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dir WHERE { ?id rdfop:tabDirection ?dir }
BEGIN
?><div class='rdfop-c rdfop-tabs rdfop-tabs--<?rdf PRINT HTML ?dir ?>' data-testid='<?rdf PRINT HTML ?id ?>' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' data-rdfop-dir='<?rdf PRINT HTML ?dir ?>'>
  <div class='rdfop-tabs__bar' ondragover='rdfopTabsBarDragOver(event,this)' ondrop='rdfopTabsBarDrop(event,this)'>
    <button class='rdfop-tabs__dir' onclick='rdfopTabsDirection(this.closest(&quot;.rdfop-tabs__bar&quot;))'>&#x2B82;</button>
    <?rdf
    SELECT ?tab, ?label, ?ord, ?child WHERE { ?tab rdfop:order ?ord . ?id rdfop:children ?tab . ?tab a rdfop:Tab . ?tab rdfop:tabLabel ?label . ?tab rdfop:children ?child } ORDER BY ?ord
    BEGIN
    ?><?rdf SELECT ?selected WHERE { ?child rdfop:selectedNode ?selected }
    BEGIN
    ?><a class='rdfop-tabs__tab' data-testid='tab:<?rdf PRINT HTML ?tab ?>' href='/view/<?rdf PRINT URL ?selected ?>' data-tab-id='<?rdf PRINT HTML ?tab ?>' data-tab-order='<?rdf PRINT HTML ?ord ?>' data-child-id='<?rdf PRINT HTML ?child ?>' data-content-id='<?rdf PRINT HTML ?selected ?>' draggable='true' ondragstart='rdfopTabsReorderStart(event)' ondragover='rdfopTabsReorderOver(event)' ondragleave='rdfopTabsReorderLeave(event)' ondrop='rdfopTabsReorderDrop(event)' ondragend='rdfopTabsReorderEnd(event)' onclick='event.preventDefault();rdfopTabsSwitch(this)'>
      <span class='rdfop-c rdfop-textedit' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?tab ?>,&quot;p&quot;:&quot;https://launix.de/rdfop/schema#tabLabel&quot;}' ondblclick='event.stopPropagation();rdfopSwap(this,&quot;edit&quot;)'><?rdf PRINT HTML ?label ?></span>
      <span class='rdfop-tabs__close' onclick='event.preventDefault();event.stopPropagation();rdfopTabClose(this.closest(&quot;.rdfop-tabs__tab&quot;))'>&#x2715;</span>
    </a><?rdf
    ELSE
    ?><a class='rdfop-tabs__tab' data-testid='tab:<?rdf PRINT HTML ?tab ?>' href='/view/<?rdf PRINT URL ?child ?>' data-tab-id='<?rdf PRINT HTML ?tab ?>' data-tab-order='<?rdf PRINT HTML ?ord ?>' data-child-id='<?rdf PRINT HTML ?child ?>' data-content-id='<?rdf PRINT HTML ?child ?>' draggable='true' ondragstart='rdfopTabsReorderStart(event)' ondragover='rdfopTabsReorderOver(event)' ondragleave='rdfopTabsReorderLeave(event)' ondrop='rdfopTabsReorderDrop(event)' ondragend='rdfopTabsReorderEnd(event)' onclick='event.preventDefault();rdfopTabsSwitch(this)'>
      <span class='rdfop-c rdfop-textedit' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?tab ?>,&quot;p&quot;:&quot;https://launix.de/rdfop/schema#tabLabel&quot;}' ondblclick='event.stopPropagation();rdfopSwap(this,&quot;edit&quot;)'><?rdf PRINT HTML ?label ?></span>
      <span class='rdfop-tabs__close' onclick='event.preventDefault();event.stopPropagation();rdfopTabClose(this.closest(&quot;.rdfop-tabs__tab&quot;))'>&#x2715;</span>
    </a><?rdf
    END ?><?rdf
    END
    ?>
    <button class='rdfop-tabs__add' onclick='rdfopTabsAdd(this)'>+</button>
  </div>
  <div class='rdfop-tabs__content'>
    <?rdf
    SELECT ?tab, ?child, ?ord WHERE { ?tab rdfop:order ?ord . ?id rdfop:children ?tab . ?tab a rdfop:Tab . ?tab rdfop:children ?child } ORDER BY ?ord
    BEGIN
    ?><div class='rdfop-tabs__panel' data-testid='panel:<?rdf PRINT HTML ?tab ?>' data-tab-id='<?rdf PRINT HTML ?tab ?>' data-child-id='<?rdf PRINT HTML ?child ?>'><?rdf CALL render_object(?child, REQ, RES) ?></div><?rdf
    END
    ?>
  </div>
</div>
<?rdf
END""" .

################################################################
# Tests
################################################################

rdfop:test_tab_add_appends_last a rdfop:PlaywrightTest ;
  rdfs:label "Tab add appends new tab at the end" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "20" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const selA = helpers.id();
const selB = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabA, 'Alpha', '1', selA),
  helpers.tab(group, tabB, 'Beta', '2', selB),
  helpers.selector(selA, leafA),
  helpers.selector(selB, leafB),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
].join('\n'));
try {
  await helpers.goto(root);
  await expect(helpers.tabLabels(group)).toHaveText(['Alpha', 'Beta']);
  await helpers.byId(group).locator('.rdfop-tabs__add').click();
  await expect(helpers.tabLabels(group)).toHaveText(['Alpha', 'Beta', 'New Tab']);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_tab_to_edge_moves_and_dissolves_source_tab a rdfop:PlaywrightTest ;
  rdfs:label "Dragging tab content to edge of another tab removes the source tab" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "30" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const selA = helpers.id();
const selB = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabA, 'Alpha', '1', selA),
  helpers.tab(group, tabB, 'Beta', '2', selB),
  helpers.selector(selA, leafA),
  helpers.selector(selB, leafB),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
].join('\n'));
try {
  await helpers.goto(root);
  await helpers.dragComponentViaTab(selA, tabB, selB, 'bottom');
  await expect(helpers.tabLabels(group)).toHaveText(['Beta']);
  await expect(helpers.byId(selA)).toHaveCount(0);
  await expect(page.locator('.rdfop-split')).toHaveCount(1);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_tab_to_tab_center_swap a rdfop:PlaywrightTest ;
  rdfs:label "Dragging tab content to another tab center swaps both contents" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "40" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const selA = helpers.id();
const selB = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabA, 'Alpha', '1', selA),
  helpers.tab(group, tabB, 'Beta', '2', selB),
  helpers.selector(selA, leafA),
  helpers.selector(selB, leafB),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
].join('\n'));
try {
  await helpers.goto(root);
  await helpers.dragComponentViaTab(selA, tabB, selB, 'center');
  await expect(helpers.tabLabels(group)).toHaveText(['Alpha', 'Beta']);
  await expect(helpers.byId(selA)).toHaveAttribute('data-selected', leafB);
  await expect(helpers.byId(selB)).toHaveAttribute('data-selected', leafA);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_tab_reorder_persists a rdfop:PlaywrightTest ;
  rdfs:label "Tab reorder moves the dragged tab before the target and survives reload" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "50" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const tabC = helpers.id();
const selA = helpers.id();
const selB = helpers.id();
const selC = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
const leafC = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabA, 'Alpha', '1', selA),
  helpers.tab(group, tabB, 'Beta', '2', selB),
  helpers.tab(group, tabC, 'Gamma', '3', selC),
  helpers.selector(selA, leafA),
  helpers.selector(selB, leafB),
  helpers.selector(selC, leafC),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
  helpers.htmlView(leafC, 'Gamma'),
].join('\n'));
try {
  await helpers.goto(root);
  await helpers.reorderTab(tabC, tabA, 'before');
  await expect(helpers.tabLabels(group)).toHaveText(['Gamma', 'Alpha', 'Beta']);
  await page.reload();
  await expect(helpers.tabLabels(group)).toHaveText(['Gamma', 'Alpha', 'Beta']);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_external_palette_to_tab_header_inserts_and_cleans_source a rdfop:PlaywrightTest ;
  rdfs:label "External palette drop onto a tab header inserts there and cleans up the source tab" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "55" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabSource = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const selSource = helpers.id();
const selA = helpers.id();
const selB = helpers.id();
const leafSource = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabSource, 'Source', '1', selSource),
  helpers.tab(group, tabA, 'Alpha', '2', selA),
  helpers.tab(group, tabB, 'Beta', '3', selB),
  helpers.selector(selSource, leafSource),
  helpers.selector(selA, leafA),
  helpers.selector(selB, leafB),
  helpers.htmlView(leafSource, 'Source'),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
].join('\\n'));
try {
  await helpers.goto(root);
  await helpers.byId(group).waitFor({ state: 'attached' });
  await expect(helpers.tabLabels(group)).toHaveText(['Source', 'Alpha', 'Beta']);
  await helpers.dragExternalComponentToTabHeader({
    contentId: leafSource,
    sourcePayload: { kind: 'selector', selectorId: selSource, contentId: leafSource },
    targetTabId: tabB,
    side: 'before'
  });
  await expect(helpers.tabById(tabSource)).toHaveCount(0);
  const tabIds = await helpers.tabIds(group);
  expect(tabIds).toHaveLength(3);
  expect(tabIds[0]).toBe(tabA);
  expect(tabIds[2]).toBe(tabB);
  expect(tabIds).not.toContain(tabSource);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_split_child_to_new_tab a rdfop:PlaywrightTest ;
  rdfs:label "Dragging one split child to the tab bar creates a new trailing tab" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "60" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabMain = helpers.id();
const tabSel = helpers.id();
const split = helpers.id();
const leftSel = helpers.id();
const rightSel = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabMain, 'Main', '1', tabSel),
  helpers.selector(tabSel, split),
  helpers.split(split, 'horizontal', '0.5', leftSel, rightSel),
  helpers.selector(leftSel, leafA),
  helpers.selector(rightSel, leafB),
  helpers.htmlView(leafA, 'Alpha'),
  helpers.htmlView(leafB, 'Beta'),
].join('\n'));
try {
  await helpers.goto(root);
  await helpers.dragComponentToTabBar(rightSel, group);
  await expect(helpers.tabLabels(group)).toHaveCount(2);
  await helpers.clickTab(tabMain);
  await expect(helpers.byId(tabSel)).toHaveAttribute('data-selected', leafA);
  await expect(helpers.byId(split)).toHaveCount(0);
} finally {
  await helpers.cleanup(root);
}
""" .

rdfop:test_split_child_to_other_tab_split_child a rdfop:PlaywrightTest ;
  rdfs:label "Dragging a split child into another tab split child hovers the tab and keeps both tabs consistent" ;
  rdfop:testFor rdfop:TabGroup ;
  rdfop:order "70" ;
  rdfop:playwright """
const root = helpers.id();
const group = helpers.id();
const tabA = helpers.id();
const tabB = helpers.id();
const tabSelA = helpers.id();
const tabSelB = helpers.id();
const splitA = helpers.id();
const splitB = helpers.id();
const leftSelA = helpers.id();
const rightSelA = helpers.id();
const leftSelB = helpers.id();
const rightSelB = helpers.id();
const leafA = helpers.id();
const leafB = helpers.id();
const leafC = helpers.id();
const leafD = helpers.id();
await helpers.insert([
  helpers.selector(root, group),
  helpers.tabGroup(group),
  helpers.tab(group, tabA, 'Alpha', '1', tabSelA),
  helpers.tab(group, tabB, 'Beta', '2', tabSelB),
  helpers.selector(tabSelA, splitA),
  helpers.selector(tabSelB, splitB),
  helpers.split(splitA, 'horizontal', '0.5', leftSelA, rightSelA),
  helpers.split(splitB, 'horizontal', '0.5', leftSelB, rightSelB),
  helpers.selector(leftSelA, leafA),
  helpers.selector(rightSelA, leafB),
  helpers.selector(leftSelB, leafC),
  helpers.selector(rightSelB, leafD),
  helpers.htmlView(leafA, 'A'),
  helpers.htmlView(leafB, 'B'),
  helpers.htmlView(leafC, 'C'),
  helpers.htmlView(leafD, 'D'),
].join('\n'));
try {
  await helpers.goto(root);
  await helpers.dragComponentViaTab(rightSelA, tabB, leftSelB, 'bottom');
  await helpers.clickTab(tabA);
  await expect(helpers.byId(tabSelA)).toHaveAttribute('data-selected', leafA);
  await expect(helpers.byId(splitA)).toHaveCount(0);
  await helpers.clickTab(tabB);
  const selected = await helpers.byId(leftSelB).getAttribute('data-selected');
  expect(selected).not.toBe(leafC);
  await expect(helpers.panelById(tabB)).toHaveClass(/rdfop-tabs__panel--active/);
} finally {
  await helpers.cleanup(root);
}
""" .
