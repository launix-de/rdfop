@prefix rdfop: <https://launix.de/rdfop/schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# RDFOP Final Self-Describing Schema
################################################################

# Classes
rdfop:EntityType a rdfs:Class .
rdfop:Attribute a rdfs:Class .
rdfop:EditorComponent a rdfs:Class .
rdfop:CodeGenerator a rdfs:Class .
rdfop:Expr a rdfs:Class .
rdfop:Parameter a rdfs:Class .
rdfop:ChangeSet a rdfs:Class .
rdfop:Tenant a rdfs:Class .
# TODO: rdfop:Enum

# TODO: owl:cardinality 1 for required attributes
# TODO: owl:minCardinality 1 for required multi-attributes
# TODO: owl:maxCardinality 1 for optional attributes
# TODO: schema verifier inside the transaction

# Entity / Attribute definitions
rdfop:hasAttribute a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:Attribute .
rdfop:attrName a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal .
rdfop:attrType a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Resource . # reference to type or datatype
rdfop:cardinality a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal . # "0..1", "1", "0..n"
rdfop:attrKind a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal .
rdfop:recursiveDelete a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .

# Editor components
/* view/edit predicates link EntityType → EditorComponent: e.g. rdfop:HTMLView rdfop:view rdfop:HTMLView_view */
rdfop:view a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:EditorComponent .
rdfop:edit a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:EditorComponent .
rdfop:componentTemplate a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # RDFHP template string
rdfop:parameters a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # parameters required to instantiate
rdfop:input a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # RDFJSON query for data + provenance
rdfop:inputVariable a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # bind JSON to this variable name
rdfop:initTemplate a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # JSON object for new items

# Code Generators
rdfop:handlesNodeType a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfop:EntityType .
rdfop:language a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfs:Literal .
rdfop:template a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfs:Literal .

# Expressions (TODO: add more Classes: ExprConstant, ExprUnaryOperator, ExprBinaryOperator and diversify)
rdfop:operator a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdfs:Literal .
rdfop:left a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdf:Resource .
rdfop:right a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdf:Resource .
rdfop:value a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdfs:Literal .

# Labels and localization
rdfs:label a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdfs:Literal .

################################################################
# Runtime View Components (bootstrap)
################################################################

# Property to map a type to a view function name
rdfop:viewFunction a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .
rdfop:viewTemplate a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .

# Component type: HTMLView
rdfop:HTMLView a rdfop:EntityType .

# Attribute for HTMLView content
rdfop:html a rdf:Property ; rdfs:domain rdfop:HTMLView ; rdfs:range rdfs:Literal .

# HTMLView components
rdfop:HTMLView rdfop:view rdfop:HTMLView_view .
rdfop:HTMLView rdfop:edit rdfop:HTMLEdit .

rdfop:HTMLView_view a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?h WHERE { ?id rdfop:html ?h }
BEGIN
?><div class='rdfop-c' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:&quot;https://launix.de/rdfop/schema#html&quot;}'>
  <button class='rdfop-edit-btn' onclick='rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;edit&quot;)'>&#x270E;</button>
  <?rdf PRINT RAW ?h ?>
</div><?rdf
END""" .

# HTMLView: "edit" component — HTMLEdit: textarea with save/cancel
rdfop:HTMLEdit a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><div class='rdfop-c rdfop-c--editing' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' data-rdfop-old='<?rdf PRINT JSON ?val ?>'>
  <div class='rdfop-edit-toolbar'>
    <button onclick='rdfopCommit(this)'>&#x2714;</button>
    <button onclick='rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;view&quot;)'>&#x2718;</button>
  </div>
  <!-- TODO: TinyMCE -->
  <textarea class='rdfop-editor'><?rdf PRINT HTML ?val ?></textarea>
</div><?rdf
END""" .

# TextEdit: inline single-line string editor (view = span with dblclick, edit = input)
# Generic — can be used for any type via direct render_component call
rdfop:Tab rdfop:view rdfop:TextEdit_view .
rdfop:Tab rdfop:edit rdfop:TextEdit_edit .

rdfop:TextEdit_view a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><span class='rdfop-c rdfop-textedit' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' ondblclick='rdfopSwap(this,&quot;edit&quot;)'><?rdf PRINT HTML ?val ?></span><?rdf
END""" .

rdfop:TextEdit_edit a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><span class='rdfop-c rdfop-textedit rdfop-textedit--editing' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' data-rdfop-old='<?rdf PRINT JSON ?val ?>'><input type='text' value='<?rdf PRINT HTML ?val ?>' onkeydown='if(event.key==&quot;Enter&quot;)rdfopCommit(this);if(event.key==&quot;Escape&quot;)rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;view&quot;)' onblur='rdfopCommit(this)' autofocus></span><?rdf
END""" .


################################################################
# Layout Components
################################################################

# Tree structure properties (shared by all layout nodes)
rdfop:parent a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdf:Resource .
rdfop:children a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdf:Resource .
rdfop:order a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdfs:Literal .

# --- TabGroup ---
rdfop:TabGroup a rdfop:EntityType .
rdfop:tabDirection a rdf:Property ; rdfs:domain rdfop:TabGroup ; rdfs:range rdfs:Literal .
rdfop:paletteVisible a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .
rdfop:TabGroup rdfop:paletteVisible true .
rdfop:HTMLView rdfop:paletteVisible true .

# --- Tab ---
rdfop:Tab a rdfop:EntityType .
rdfop:tabLabel a rdf:Property ; rdfs:domain rdfop:Tab ; rdfs:range rdfs:Literal .

# TabGroup components
rdfop:TabGroup rdfop:view rdfop:TabGroup_view .

rdfop:TabGroup_view a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dir WHERE { ?id rdfop:tabDirection ?dir }
BEGIN
?><div class='rdfop-c rdfop-tabs rdfop-tabs--<?rdf PRINT HTML ?dir ?>' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}'>
  <div class='rdfop-tabs__bar'>
    <?rdf
    SELECT ?tab, ?label WHERE { ?tab rdfop:parent ?id . ?tab a rdfop:Tab . ?tab rdfop:tabLabel ?label }
    BEGIN
    ?><div class='rdfop-tabs__tab' data-tab-id='<?rdf PRINT HTML ?tab ?>' onclick='(function(t){var tabs=t.closest(&quot;.rdfop-tabs&quot;);tabs.querySelectorAll(&quot;.rdfop-tabs__tab&quot;).forEach(function(x){x.classList.remove(&quot;rdfop-tabs__tab--active&quot;)});tabs.querySelectorAll(&quot;.rdfop-tabs__panel&quot;).forEach(function(x){x.classList.remove(&quot;rdfop-tabs__panel--active&quot;)});t.classList.add(&quot;rdfop-tabs__tab--active&quot;);var p=tabs.querySelector(&quot;.rdfop-tabs__panel[data-tab-id=\x27&quot;+t.dataset.tabId+&quot;\x27]&quot;);if(p)p.classList.add(&quot;rdfop-tabs__panel--active&quot;)})(this)'>
      <span class='rdfop-tabs__label'><?rdf PRINT HTML ?label ?></span>
    </div><?rdf
    END
    ?>
    <button class='rdfop-tabs__add' onclick='rdfopCreate(this,&quot;<?rdf PRINT HTML ?id ?>&quot;,&quot;https://launix.de/rdfop/schema#Tab&quot;)'>+</button>
  </div>
  <div class='rdfop-tabs__content'>
    <?rdf
    SELECT ?tab, ?child WHERE { ?tab rdfop:parent ?id . ?tab a rdfop:Tab . ?tab rdfop:children ?child }
    BEGIN
    ?><div class='rdfop-tabs__panel' data-tab-id='<?rdf PRINT HTML ?tab ?>'><?rdf CALL render_object(?child, REQ, RES) ?></div><?rdf
    END
    ?>
  </div>
</div>
<script>(function(){var tabs=document.currentScript.previousElementSibling;var first=tabs.querySelector('.rdfop-tabs__tab');if(first)first.click()})()</script><?rdf
END""" .

