@prefix rdfop: <https://launix.de/rdfop/schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# RDFOP Final Self-Describing Schema
################################################################

# Classes
rdfop:EntityType a rdfs:Class .
rdfop:Attribute a rdfs:Class .
rdfop:EditorComponent a rdfs:Class .
rdfop:CodeGenerator a rdfs:Class .
rdfop:Expr a rdfs:Class .
rdfop:Parameter a rdfs:Class .
rdfop:ChangeSet a rdfs:Class .
rdfop:Tenant a rdfs:Class .
# TODO: rdfop:Enum

# TODO: owl:cardinality 1 for required attributes
# TODO: owl:minCardinality 1 for required multi-attributes
# TODO: owl:maxCardinality 1 for optional attributes
# TODO: schema verifier inside the transaction

# Entity / Attribute definitions
rdfop:hasAttribute a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:Attribute .
rdfop:attrName a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal .
rdfop:attrType a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Resource . # reference to type or datatype
rdfop:cardinality a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal . # "0..1", "1", "0..n"
rdfop:attrKind a rdf:Property ; rdfs:domain rdfop:Attribute ; rdfs:range rdfs:Literal .
rdfop:recursiveDelete a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .

# Editor components
/* view/edit predicates link EntityType → EditorComponent: e.g. rdfop:HTMLView rdfop:view rdfop:HTMLView_view */
rdfop:view a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:EditorComponent .
rdfop:edit a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfop:EditorComponent .
rdfop:componentTemplate a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # RDFHP template string
rdfop:parameters a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # parameters required to instantiate
rdfop:input a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # RDFJSON query for data + provenance
rdfop:inputVariable a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # bind JSON to this variable name
rdfop:initTemplate a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # JSON object for new items
rdfop:css a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # CSS styles for this component
rdfop:js a rdf:Property ; rdfs:domain rdfop:EditorComponent ; rdfs:range rdfs:Literal . # JS code for this component

# Code Generators
rdfop:handlesNodeType a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfop:EntityType .
rdfop:language a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfs:Literal .
rdfop:template a rdf:Property ; rdfs:domain rdfop:CodeGenerator ; rdfs:range rdfs:Literal .

# Expressions (TODO: add more Classes: ExprConstant, ExprUnaryOperator, ExprBinaryOperator and diversify)
rdfop:operator a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdfs:Literal .
rdfop:left a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdf:Resource .
rdfop:right a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdf:Resource .
rdfop:value a rdf:Property ; rdfs:domain rdfop:Expr ; rdfs:range rdfs:Literal .

# Labels and localization
rdfs:label a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdfs:Literal .

################################################################
# Runtime View Components (bootstrap)
################################################################

# Property to map a type to a view function name
rdfop:viewFunction a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .
rdfop:viewTemplate a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .

# Component type: HTMLView
rdfop:HTMLView a rdfop:EntityType ; rdfs:label "HTML View" .
rdfop:HTMLView rdfop:initTemplate """$ID <https://launix.de/rdfop/schema#html> "<p>Click the pencil to edit.</p>" .
""" .

# Attribute for HTMLView content
rdfop:html a rdf:Property ; rdfs:domain rdfop:HTMLView ; rdfs:range rdfs:Literal .

# HTMLView components
rdfop:HTMLView rdfop:view rdfop:HTMLView_view .
rdfop:HTMLView rdfop:edit rdfop:HTMLEdit .

rdfop:HTMLView_view a rdfop:EditorComponent ;
  rdfop:css """.rdfop-edit-btn { position: absolute; top: 34px; right: 12px; background: var(--panel); border: 1px solid var(--ring); border-radius: 6px; padding: 4px 8px; cursor: pointer; font-size: 16px; line-height: 1; z-index: 10; opacity: 0; transition: opacity .15s; }
.rdfop-c:hover > .rdfop-edit-btn { opacity: 1; }
.rdfop-edit-btn:hover { background: #f1f5f9; }""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?h WHERE { ?id rdfop:html ?h }
BEGIN
?><div class='rdfop-c' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:&quot;https://launix.de/rdfop/schema#html&quot;}'>
  <button class='rdfop-edit-btn' onclick='rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;edit&quot;)'>&#x270E;</button>
  <?rdf PRINT RAW ?h ?>
</div><?rdf
END""" .

# HTMLView: "edit" component — HTMLEdit: textarea with save/cancel
rdfop:HTMLEdit a rdfop:EditorComponent ;
  rdfop:css """.rdfop-edit-toolbar { display: flex; gap: 6px; justify-content: flex-end; padding: 8px 12px 0; }
.rdfop-edit-toolbar button { background: var(--panel); border: 1px solid var(--ring); border-radius: 6px; padding: 4px 10px; cursor: pointer; font-size: 16px; }
.rdfop-edit-toolbar button:hover { background: #f1f5f9; }
.rdfop-c--editing { display: flex; flex-direction: column; width: 100%; height: 100%; overflow: hidden; }
.rdfop-editor { flex: 1; width: 100%; font-family: monospace; font-size: 13px; border: none; padding: 10px 12px; resize: none; box-sizing: border-box; outline: none; }""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><div class='rdfop-c rdfop-c--editing' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' data-rdfop-old='<?rdf PRINT JSON ?val ?>'>
  <div class='rdfop-edit-toolbar'>
    <button onclick='rdfopCommit(this)'>&#x2714;</button>
    <button onclick='rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;view&quot;)'>&#x2718;</button>
  </div>
  <!-- TODO: TinyMCE -->
  <textarea class='rdfop-editor'><?rdf PRINT HTML ?val ?></textarea>
</div><?rdf
END""" .

# TextEdit: inline single-line string editor (view = span with dblclick, edit = input)
# Generic — can be used for any type via direct render_component call
rdfop:Tab rdfop:view rdfop:TextEdit_view .
rdfop:Tab rdfop:edit rdfop:TextEdit_edit .

rdfop:TextEdit_view a rdfop:EditorComponent ;
  rdfop:css """.rdfop-textedit { cursor: default; min-width: 40px; display: inline-block; }
.rdfop-textedit--editing { position: relative; z-index: 1001; }
.rdfop-textedit--editing input { font: inherit; border: none; background: transparent; padding: 0; margin: 0; outline: none; width: 1ch; position: relative; z-index: 1002; }
.rdfop-textedit-overlay { position: fixed; inset: 0; z-index: 1000; }""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><span class='rdfop-c rdfop-textedit' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' ondblclick='rdfopSwap(this,&quot;edit&quot;)'><?rdf PRINT HTML ?val ?></span><?rdf
END""" .

rdfop:TextEdit_edit a rdfop:EditorComponent ;
  rdfop:js """
window.rdfopTextFit = function(i) {
  var c = document.createElement('canvas');
  var w = c.getContext('2d');
  w.font = getComputedStyle(i).font;
  i.style.width = Math.ceil(w.measureText(i.value || 'M').width + 4) + 'px';
};""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
PARAMETER ?p "p"
SELECT ?val WHERE { ?id ?p ?val }
BEGIN
?><span class='rdfop-c rdfop-textedit rdfop-textedit--editing' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>,&quot;p&quot;:<?rdf PRINT JSON ?p ?>}' data-rdfop-old='<?rdf PRINT JSON ?val ?>'><div class='rdfop-textedit-overlay' onclick='rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;view&quot;)'></div><input type='text' value='<?rdf PRINT HTML ?val ?>' oninput='rdfopTextFit(this)' onkeydown='if(event.key==&quot;Enter&quot;){event.preventDefault();rdfopCommit(this)}if(event.key==&quot;Escape&quot;)rdfopSwap(this.closest(&quot;.rdfop-c&quot;),&quot;view&quot;)'></span><?rdf
END""" .


################################################################
# Tool Components
################################################################

# --- Explorer ---
rdfop:Explorer a rdfop:EntityType ; rdfs:label "Explorer" .
rdfop:Explorer rdfop:paletteVisible "true" .
rdfop:Explorer rdfop:view rdfop:Explorer_view .

rdfop:Explorer_view a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dummy WHERE { ?id a rdfop:Explorer }
BEGIN
?><div class='rdfop-c' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' style='padding:1em'>
  <h2>Knowledge base</h2>
  <div class='card'>
    <table class='table'>
      <tr><th>Object</th><th>Type</th></tr>
      <?rdf
      SELECT ?s, ?o WHERE { ?s a ?o }
      BEGIN
      ?><tr>
        <td><a href='view?id=<?rdf PRINT URL ?s ?>' onclick='return openOverlayLink(this)'><?rdf PRINT HTML ?s ?></a></td>
        <td><?rdf PRINT HTML ?o ?></td>
      </tr><?rdf
      END
      ?>
    </table>
  </div>
  <h3 class='mt-4'>RDF console</h3>
  <div class='card pad'>
    <form class='overlay-form' method='POST' action='rdf'>
      <textarea class='input w-100 h-30vh' name='rdf'>SELECT ?s, ?p, ?o WHERE {?s ?p ?o}</textarea>
      <div class='mt-2'>
        <button class='btn primary' type='submit'>Execute</button>
      </div>
    </form>
  </div>
</div><?rdf
END""" .

# --- SPARQLConsole ---
rdfop:SPARQLConsole a rdfop:EntityType ; rdfs:label "SPARQL Console" .
rdfop:SPARQLConsole rdfop:paletteVisible "true" .
rdfop:SPARQLConsole rdfop:view rdfop:SPARQLConsole_view .

rdfop:SPARQLConsole_view a rdfop:EditorComponent ;
  rdfop:css """.rdfop-sparql { display:flex; flex-direction:column; height:100%; padding:1em; box-sizing:border-box; }
.rdfop-sparql__editor { flex-shrink:0; }
.rdfop-sparql__results { flex:1; overflow:auto; margin-top:1em; }""" ;
  rdfop:js """
window.rdfopSparqlExec = async function(btn) {
  var form = btn.closest('form');
  var results = form.closest('.rdfop-sparql').querySelector('.rdfop-sparql__results');
  var body = new URLSearchParams(new FormData(form)).toString();
  var resp = await fetch('/rdf', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:body });
  results.innerHTML = await resp.text();
};""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dummy WHERE { ?id a rdfop:SPARQLConsole }
BEGIN
?><div class='rdfop-c rdfop-sparql' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}'>
  <div class='rdfop-sparql__editor'>
    <h3>SPARQL Console</h3>
    <form>
      <textarea class='input w-100' name='rdf' style='min-height:15vh' onkeydown='if(event.ctrlKey&amp;&amp;event.key==&quot;Enter&quot;){event.preventDefault();rdfopSparqlExec(this)}'>SELECT ?s, ?p, ?o WHERE {?s ?p ?o}</textarea>
      <div class='mt-2'>
        <button class='btn primary' type='button' onclick='rdfopSparqlExec(this)'>Execute</button>
      </div>
    </form>
  </div>
  <div class='rdfop-sparql__results'></div>
</div><?rdf
END""" .

# --- TTLImport ---
rdfop:TTLImport a rdfop:EntityType ; rdfs:label "TTL Import" .
rdfop:TTLImport rdfop:paletteVisible "true" .
rdfop:TTLImport rdfop:view rdfop:TTLImport_view .

rdfop:TTLImport_view a rdfop:EditorComponent ;
  rdfop:js """
window.rdfopTtlImport = async function(btn) {
  var form = btn.closest('form');
  var results = form.closest('.rdfop-c').querySelector('.rdfop-ttl-results');
  var body = new URLSearchParams(new FormData(form)).toString();
  var resp = await fetch('/ttl-import', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:body });
  results.innerHTML = await resp.text();
};""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dummy WHERE { ?id a rdfop:TTLImport }
BEGIN
?><div class='rdfop-c' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' style='padding:1em'>
  <h2>TTL import</h2>
  <p class='muted'>Paste Turtle data below or choose a .ttl file.</p>
  <div class='card pad'>
    <form>
      <textarea class='input w-100 h-30vh' name='ttl' placeholder='@prefix ex: &lt;http://example.com#&gt; .&#10;ex:foo a ex:Thing .'></textarea>
      <div class='mt-2'>
        <button class='btn primary' type='button' onclick='rdfopTtlImport(this)'>Import</button>
      </div>
    </form>
  </div>
  <div class='rdfop-ttl-results'></div>
</div><?rdf
END""" .

# --- Settings ---
rdfop:Settings a rdfop:EntityType ; rdfs:label "Settings" .
rdfop:Settings rdfop:paletteVisible "true" .
rdfop:Settings rdfop:view rdfop:Settings_view .

rdfop:Settings_view a rdfop:EditorComponent ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dummy WHERE { ?id a rdfop:Settings }
BEGIN
?><div class='rdfop-c' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' style='padding:1em'>
  <h2>Settings</h2>
  <p style='color:var(--muted)'>Project configuration will appear here.</p>
</div><?rdf
END""" .

################################################################
# Layout Components
################################################################

# Tree structure properties (shared by all layout nodes)
rdfop:parent a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdf:Resource .
rdfop:children a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdf:Resource .
rdfop:order a rdf:Property ; rdfs:domain rdf:Resource ; rdfs:range rdfs:Literal .

# --- ComponentSelector ---
rdfop:ComponentSelector a rdfop:EntityType .
rdfop:selectedNode a rdf:Property ; rdfs:domain rdfop:ComponentSelector ; rdfs:range rdf:Resource .
rdfop:ComponentSelector rdfop:view rdfop:ComponentSelector_view .

rdfop:ComponentSelector_view a rdfop:EditorComponent ;
  rdfop:css """.rdfop-palette { display: flex; flex-wrap: wrap; gap: 12px; padding: 1em; align-content: flex-start; }
.rdfop-palette__item { background: var(--panel); border: 1px solid var(--ring); border-radius: 10px; padding: 16px 20px; cursor: pointer; min-width: 120px; text-align: center; transition: box-shadow .15s, transform .15s; }
.rdfop-palette__item:hover { box-shadow: 0 4px 12px rgba(2,6,23,.12); transform: translateY(-2px); }
.rdfop-selector--filled { position: relative; width: 100%; height: 100%; }
.rdfop-selector__clear { position: absolute; top: 4px; right: 4px; background: var(--panel); border: 1px solid var(--ring); border-radius: 50%; width: 22px; height: 22px; cursor: pointer; font-size: 12px; line-height: 20px; text-align: center; z-index: 10; opacity: 0; transition: opacity .15s; }
.rdfop-selector--filled:hover > .rdfop-selector__clear { opacity: 1; }
.rdfop-selector__clear:hover { color: #ef4444; border-color: #ef4444; }""" ;
  rdfop:js """
window.rdfopPaletteSelect = async function(btn, selectorId, typeName) {
  var resp = await fetch('/rdfop-create', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'parent=' + encodeURIComponent(selectorId) + '&type=' + encodeURIComponent(typeName)
  });
  if (!resp.ok) return;
  var newId = (await resp.text()).trim();
  /* store selectedNode on the selector */
  var sid = selectorId.includes(':') ? '<' + selectorId + '>' : selectorId;
  await rdfopSave(null, sid + ' <https://launix.de/rdfop/schema#selectedNode> <' + newId + '> .');
  /* re-render the selector */
  var el = btn.closest('.rdfop-c');
  rdfopSwap(el, 'view');
};
window.rdfopSelectorClear = async function(btn) {
  if (!confirm('Remove this component?')) return;
  var el = btn.closest('.rdfop-selector--filled');
  var p = JSON.parse(el.dataset.rdfopParams || '{}');
  var sid = p.id.includes(':') ? '<' + p.id + '>' : p.id;
  var selId = el.dataset.selected;
  if (selId) {
    await fetch('/rdfop-delete', {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: 'id=' + encodeURIComponent(selId)
    });
    var selSid = selId.includes(':') ? '<' + selId + '>' : selId;
    await rdfopSave(sid + ' <https://launix.de/rdfop/schema#selectedNode> ' + selSid + ' .', null);
  }
  rdfopSwap(el, 'view');
};""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
@PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PARAMETER ?id "id"
SELECT ?sel WHERE { ?id rdfop:selectedNode ?sel }
BEGIN
?><div class='rdfop-c rdfop-selector--filled' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' data-selected='<?rdf PRINT HTML ?sel ?>'>
  <button class='rdfop-selector__clear' onclick='event.stopPropagation();rdfopSelectorClear(this)'>&#x2715;</button>
  <?rdf CALL render_object(?sel, REQ, RES) ?>
</div><?rdf
ELSE
?><div class='rdfop-c rdfop-palette' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}'>
  <?rdf SELECT ?type, ?label WHERE { ?type rdfop:paletteVisible "true" . ?type a rdfop:EntityType . ?type rdfs:label ?label }
  BEGIN
  ?><div class='rdfop-palette__item' onclick='rdfopPaletteSelect(this,<?rdf PRINT JSON ?id ?>,&quot;<?rdf PRINT HTML ?type ?>&quot;)'><?rdf PRINT HTML ?label ?></div><?rdf
  END ?>
</div><?rdf
END""" .

# --- TabGroup ---
rdfop:TabGroup a rdfop:EntityType ; rdfs:label "Tab Group" .
rdfop:TabGroup rdfop:initTemplate """$ID <https://launix.de/rdfop/schema#tabDirection> "top" .
""" .
rdfop:tabDirection a rdf:Property ; rdfs:domain rdfop:TabGroup ; rdfs:range rdfs:Literal .
rdfop:paletteVisible a rdf:Property ; rdfs:domain rdfop:EntityType ; rdfs:range rdfs:Literal .
rdfop:TabGroup rdfop:paletteVisible "true" .
rdfop:HTMLView rdfop:paletteVisible "true" .

# --- Split ---
rdfop:Split a rdfop:EntityType .
rdfop:splitDirection a rdf:Property ; rdfs:domain rdfop:Split ; rdfs:range rdfs:Literal .
rdfop:splitRatio a rdf:Property ; rdfs:domain rdfop:Split ; rdfs:range rdfs:Literal .
rdfop:Split rdfop:view rdfop:Split_view .

# Split palette entries: horizontal and vertical
rdfop:SplitH a rdfop:EntityType ; rdfs:label "Split ↔" .
rdfop:SplitH rdfop:paletteVisible "true" .
rdfop:SplitH rdfop:view rdfop:Split_view .
rdfop:SplitH rdfop:initTemplate """$ID a <https://launix.de/rdfop/schema#Split> .
$ID <https://launix.de/rdfop/schema#splitDirection> "horizontal" .
$ID <https://launix.de/rdfop/schema#splitRatio> "0.64" .
$ID <https://launix.de/rdfop/schema#children> _:left .
$ID <https://launix.de/rdfop/schema#children> _:right .
_:left a <https://launix.de/rdfop/schema#ComponentSelector> .
_:left <https://launix.de/rdfop/schema#parent> $ID .
_:left <https://launix.de/rdfop/schema#order> "1" .
_:right a <https://launix.de/rdfop/schema#ComponentSelector> .
_:right <https://launix.de/rdfop/schema#parent> $ID .
_:right <https://launix.de/rdfop/schema#order> "2" .
""" .

rdfop:SplitV a rdfop:EntityType ; rdfs:label "Split ↕" .
rdfop:SplitV rdfop:paletteVisible "true" .
rdfop:SplitV rdfop:view rdfop:Split_view .
rdfop:SplitV rdfop:initTemplate """$ID a <https://launix.de/rdfop/schema#Split> .
$ID <https://launix.de/rdfop/schema#splitDirection> "vertical" .
$ID <https://launix.de/rdfop/schema#splitRatio> "0.64" .
$ID <https://launix.de/rdfop/schema#children> _:top .
$ID <https://launix.de/rdfop/schema#children> _:bottom .
_:top a <https://launix.de/rdfop/schema#ComponentSelector> .
_:top <https://launix.de/rdfop/schema#parent> $ID .
_:top <https://launix.de/rdfop/schema#order> "1" .
_:bottom a <https://launix.de/rdfop/schema#ComponentSelector> .
_:bottom <https://launix.de/rdfop/schema#parent> $ID .
_:bottom <https://launix.de/rdfop/schema#order> "2" .
""" .

rdfop:Split_view a rdfop:EditorComponent ;
  rdfop:css """.rdfop-split { display: flex; width: 100%; height: 100%; }
.rdfop-split--horizontal { flex-direction: row; }
.rdfop-split--vertical { flex-direction: column; }
.rdfop-split__pane { overflow: auto; flex: calc(1 - var(--ratio, 0.5)) 0 0%; }
.rdfop-split__pane:first-child { flex: var(--ratio, 0.5) 0 0%; }
.rdfop-split__pane:nth-child(1) { order: 0; }
.rdfop-split__separator { order: 1; background: var(--ring); transition: background .15s; }
.rdfop-split__pane:nth-child(2) { order: 2; }
.rdfop-split--horizontal > .rdfop-split__separator { flex: 0 0 4px; cursor: col-resize; }
.rdfop-split--vertical > .rdfop-split__separator { flex: 0 0 4px; cursor: row-resize; }
.rdfop-split__separator:hover, .rdfop-split__separator.dragging { background: #0ea5e9; }""" ;
  rdfop:js """
window.rdfopSplitDrag = function(sep) {
  var split = sep.closest('.rdfop-split');
  var panes = Array.from(split.querySelectorAll(':scope > .rdfop-split__pane'));
  if (panes.length < 2) return;
  var p = JSON.parse(split.dataset.rdfopParams || '{}');
  var isH = split.classList.contains('rdfop-split--horizontal');
  var oldRatio = parseFloat(split.dataset.rdfopRatio) || 0.5;
  sep.classList.add('dragging');
  var move = function(e) {
    var rect = split.getBoundingClientRect();
    var ratio = isH ? (e.clientX - rect.left) / rect.width : (e.clientY - rect.top) / rect.height;
    ratio = Math.max(0.05, Math.min(0.95, ratio));
    panes[0].style.flex = ratio + ' 0 0%';
    panes[1].style.flex = (1-ratio) + ' 0 0%';
    split.dataset.rdfopRatio = ratio;
  };
  var up = async function() {
    document.removeEventListener('mousemove', move);
    document.removeEventListener('mouseup', up);
    sep.classList.remove('dragging');
    var newRatio = split.dataset.rdfopRatio;
    if (newRatio !== String(oldRatio)) {
      var sid = p.id.includes(':') ? '<'+p.id+'>' : p.id;
      await rdfopSave(
        sid+' <https://launix.de/rdfop/schema#splitRatio> '+JSON.stringify(String(oldRatio))+' .',
        sid+' <https://launix.de/rdfop/schema#splitRatio> '+JSON.stringify(newRatio)+' .'
      );
    }
  };
  document.addEventListener('mousemove', move);
  document.addEventListener('mouseup', up);
};""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dir, ?ratio WHERE { ?id rdfop:splitDirection ?dir . ?id rdfop:splitRatio ?ratio }
BEGIN
?><div class='rdfop-c rdfop-split rdfop-split--<?rdf PRINT HTML ?dir ?>' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' data-rdfop-ratio='<?rdf PRINT HTML ?ratio ?>' style='--ratio:<?rdf PRINT HTML ?ratio ?>'>
  <?rdf
  SELECT ?child, ?ord WHERE { ?child rdfop:order ?ord . ?child rdfop:parent ?id } ORDER BY ?ord
  BEGIN
  ?><div class='rdfop-split__pane'><?rdf CALL render_object(?child, REQ, RES) ?></div><?rdf
  END
  ?>
  <div class='rdfop-split__separator' onmousedown='rdfopSplitDrag(this)'></div>
</div><?rdf
END""" .

# --- Tab ---
rdfop:Tab a rdfop:EntityType .
rdfop:tabLabel a rdf:Property ; rdfs:domain rdfop:Tab ; rdfs:range rdfs:Literal .
rdfop:Tab rdfop:initTemplate """$ID <https://launix.de/rdfop/schema#tabLabel> "New Tab" .
$ID <https://launix.de/rdfop/schema#children> _:child .
_:child a <https://launix.de/rdfop/schema#ComponentSelector> .
_:child <https://launix.de/rdfop/schema#parent> $ID .
""" .

# TabGroup components
rdfop:TabGroup rdfop:view rdfop:TabGroup_view .

rdfop:TabGroup_view a rdfop:EditorComponent ;
  rdfop:js """
window.rdfopTabDirection = window.rdfopTabDirection || function(bar) {
  var tabs = bar.closest('.rdfop-c');
  var p = JSON.parse(tabs.dataset.rdfopParams || '{}');
  var dirs = {top:'\u2B07 Tabs top',bottom:'\u2B06 Tabs bottom',left:'\u2B05 Tabs left',right:'\u2B95 Tabs right',leftRotated:'\u2934 Tabs left (rotated)',rightRotated:'\u2935 Tabs right (rotated)'};
  var menu = document.createElement('div');
  menu.className = 'rdfop-dir-menu';
  menu.style.cssText = 'position:fixed;z-index:9999;background:var(--panel);border:1px solid var(--ring);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.15);padding:4px 0';
  Object.keys(dirs).forEach(function(d) {
    var item = document.createElement('div');
    item.textContent = dirs[d];
    item.style.cssText = 'padding:6px 16px;cursor:pointer;white-space:nowrap';
    item.onmouseover = function(){item.style.background='#f1f5f9'};
    item.onmouseout = function(){item.style.background=''};
    item.onclick = async function() {
      var sid = p.id.includes(':') ? '<'+p.id+'>' : p.id;
      var oldDir = tabs.dataset.rdfopDir || 'top';
      await rdfopSave(
        sid+' <https://launix.de/rdfop/schema#tabDirection> '+JSON.stringify(oldDir)+' .',
        sid+' <https://launix.de/rdfop/schema#tabDirection> '+JSON.stringify(d)+' .'
      );
      menu.remove();
      rdfopSwap(tabs, 'view');
    };
    menu.appendChild(item);
  });
  document.body.appendChild(menu);
  var r = bar.getBoundingClientRect();
  var mw = menu.offsetWidth; var mh = menu.offsetHeight;
  var vw = window.innerWidth; var vh = window.innerHeight;
  if (r.width > r.height) {
    menu.style.left = Math.min(r.left, vw - mw) + 'px';
    menu.style.top = (r.bottom + mh > vh ? r.top - mh : r.bottom) + 'px';
  } else {
    menu.style.left = (r.right + mw > vw ? r.left - mw : r.right) + 'px';
    menu.style.top = Math.min(r.top, vh - mh) + 'px';
  }
  var close = function(e){if(!menu.contains(e.target)){menu.remove();document.removeEventListener('click',close)}};
  setTimeout(function(){document.addEventListener('click',close)},0);
};
window.rdfopDelete = window.rdfopDelete || async function(tabEl) {
  if (!confirm('Delete this tab?')) return;
  var tabId = tabEl.dataset.tabId;
  var tabs = tabEl.closest('.rdfop-c');
  var allTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
  var idx = allTabs.indexOf(tabEl);
  var nextIdx = idx < allTabs.length - 1 ? idx + 1 : idx - 1;
  var nextTabId = nextIdx >= 0 ? allTabs[nextIdx].dataset.tabId : null;
  await fetch('/rdfop-delete', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'id=' + encodeURIComponent(tabId)
  });
  var p = JSON.parse(tabs.dataset.rdfopParams || '{}');
  p.mode = 'view';
  var r = await fetch('/rdfop-render?' + new URLSearchParams(p));
  tabs.outerHTML = await r.text();
  setTimeout(function(){ var t = nextTabId ? document.querySelector('.rdfop-tabs__tab[data-tab-id=\"'+nextTabId+'\"]') : document.querySelector('.rdfop-tabs__tab'); if(t) t.click(); }, 0);
};
/* auto-activate first tab in newly rendered TabGroups */
window.rdfopTabInit = function(el) {
  var tabs = el.querySelector ? el.querySelectorAll('.rdfop-tabs') : document.querySelectorAll('.rdfop-tabs');
  tabs.forEach(function(t) {
    if (!t.querySelector('.rdfop-tabs__tab--active')) {
      var first = t.querySelector('.rdfop-tabs__tab');
      if (first) first.click();
    }
  });
};
document.addEventListener('DOMContentLoaded', function(){ rdfopTabInit(document); });
/* tab reorder via drag & drop */
window.rdfopTabDragStart = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (!tab) return;
  e.dataTransfer.setData('text/plain', tab.dataset.tabId);
  tab.classList.add('rdfop-tabs__tab--dragging');
};
window.rdfopTabDragOver = function(e) {
  e.preventDefault();
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (!tab) return;
  tab.classList.remove('rdfop-tabs__tab--dragover-before', 'rdfop-tabs__tab--dragover-after');
  var rect = tab.getBoundingClientRect();
  var tabs = tab.closest('.rdfop-c');
  var isVert = tabs && (tabs.classList.contains('rdfop-tabs--left') || tabs.classList.contains('rdfop-tabs--right') || tabs.classList.contains('rdfop-tabs--leftRotated') || tabs.classList.contains('rdfop-tabs--rightRotated'));
  var mid = isVert ? (rect.top + rect.height/2) : (rect.left + rect.width/2);
  var pos = isVert ? e.clientY : e.clientX;
  tab.classList.add(pos > mid ? 'rdfop-tabs__tab--dragover-after' : 'rdfop-tabs__tab--dragover-before');
};
window.rdfopTabDragLeave = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (tab) tab.classList.remove('rdfop-tabs__tab--dragover-before', 'rdfop-tabs__tab--dragover-after');
};
window.rdfopTabDrop = async function(e) {
  e.preventDefault();
  var targetTab = e.target.closest('.rdfop-tabs__tab');
  if (!targetTab) return;
  targetTab.closest('.rdfop-c').querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after')});
  var dragId = e.dataTransfer.getData('text/plain');
  var dropId = targetTab.dataset.tabId;
  if (dragId === dropId) return;
  var tabs = targetTab.closest('.rdfop-c');
  var allTabs = Array.from(tabs.querySelectorAll('.rdfop-tabs__tab'));
  /* determine before/after based on drop position within target */
  var rect = targetTab.getBoundingClientRect();
  var isVert = tabs.classList.contains('rdfop-tabs--left') || tabs.classList.contains('rdfop-tabs--right') || tabs.classList.contains('rdfop-tabs--leftRotated') || tabs.classList.contains('rdfop-tabs--rightRotated');
  var mid = isVert ? (rect.top + rect.height/2) : (rect.left + rect.width/2);
  var pos = isVert ? e.clientY : e.clientX;
  var insertAfter = pos > mid;
  var ids = allTabs.map(function(t){ return t.dataset.tabId; });
  ids = ids.filter(function(id){ return id !== dragId; });
  var dropIdx = ids.indexOf(dropId);
  ids.splice(insertAfter ? dropIdx + 1 : dropIdx, 0, dragId);
  /* save new orders as timestamps with 1-second gaps */
  var base = Date.now();
  for (var i = 0; i < ids.length; i++) {
    var id = ids[i];
    var sid = id.includes(':') ? '<'+id+'>' : id;
    /* find old order from DOM data attribute */
    var tabEl = allTabs.find(function(t){ return t.dataset.tabId === id; });
    var oldOrd = tabEl ? tabEl.dataset.tabOrder : null;
    var newOrd = String(base + i);
    if (oldOrd) {
      await rdfopSave(
        sid+' <https://launix.de/rdfop/schema#order> '+JSON.stringify(oldOrd)+' .',
        sid+' <https://launix.de/rdfop/schema#order> '+JSON.stringify(newOrd)+' .'
      );
    }
  }
  /* re-render */
  var p = JSON.parse(tabs.dataset.rdfopParams || '{}');
  p.mode = 'view';
  var r = await fetch('/rdfop-render?' + new URLSearchParams(p));
  var html = await r.text();
  var tpl = document.createElement('template');
  tpl.innerHTML = html;
  var node = tpl.content.firstElementChild;
  tabs.replaceWith(node);
  node.querySelectorAll('script').forEach(function(s){ eval(s.textContent); });
  if (window.rdfopTabInit) rdfopTabInit(node);
  /* activate the dragged tab */
  setTimeout(function(){ var t = node.querySelector('.rdfop-tabs__tab[data-tab-id=\"'+dragId+'\"]'); if(t) t.click(); }, 0);
};
window.rdfopTabDragEnd = function(e) {
  var tab = e.target.closest('.rdfop-tabs__tab');
  if (tab) {
    tab.classList.remove('rdfop-tabs__tab--dragging');
    tab.closest('.rdfop-c').querySelectorAll('.rdfop-tabs__tab--dragover-before,.rdfop-tabs__tab--dragover-after').forEach(function(t){t.classList.remove('rdfop-tabs__tab--dragover-before','rdfop-tabs__tab--dragover-after')});
  }
};""" ;
  rdfop:css """.rdfop-tabs { display: flex; width: 100%; height: 100%; }
.rdfop-tabs--top, .rdfop-tabs--bottom { flex-direction: column; }
.rdfop-tabs--left, .rdfop-tabs--leftRotated { flex-direction: row; }
.rdfop-tabs--right, .rdfop-tabs--rightRotated { flex-direction: row-reverse; }
.rdfop-tabs--bottom { flex-direction: column-reverse; }
.rdfop-tabs__bar { display: flex; gap: 0; background: #f1f5f9; border-bottom: 1px solid var(--ring); padding: 0 8px; flex-shrink: 0; }
.rdfop-tabs--left .rdfop-tabs__bar, .rdfop-tabs--right .rdfop-tabs__bar { flex-direction: column; width: 180px; border-bottom: none; border-right: 1px solid var(--ring); padding: 8px 0; }
.rdfop-tabs--right .rdfop-tabs__bar { border-right: none; border-left: 1px solid var(--ring); }
.rdfop-tabs--leftRotated .rdfop-tabs__bar, .rdfop-tabs--rightRotated .rdfop-tabs__bar { flex-direction: column; border-bottom: none; border-right: 1px solid var(--ring); padding: 8px 0; }
.rdfop-tabs--leftRotated .rdfop-tabs__tab { writing-mode: vertical-lr; transform: rotate(180deg); }
.rdfop-tabs--rightRotated .rdfop-tabs__tab { writing-mode: vertical-lr; }
.rdfop-tabs--leftRotated .rdfop-tabs__dir, .rdfop-tabs--rightRotated .rdfop-tabs__dir { writing-mode: horizontal-tb; }
.rdfop-tabs--leftRotated .rdfop-tabs__add, .rdfop-tabs--rightRotated .rdfop-tabs__add { writing-mode: horizontal-tb; }
.rdfop-tabs--rightRotated .rdfop-tabs__bar { border-right: none; border-left: 1px solid var(--ring); }
.rdfop-tabs__tab { padding: 8px 16px; cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; user-select: none; display: flex; align-items: center; gap: 6px; }
.rdfop-tabs__tab:hover { background: #e2e8f0; }
.rdfop-tabs__tab--active { border-bottom-color: #0ea5e9; font-weight: 600; }
.rdfop-tabs__tab--dragging { opacity: 0.4; }
.rdfop-tabs__tab--dragover-before { box-shadow: 2px 0 0 0 #0ea5e9 inset; }
.rdfop-tabs__tab--dragover-after { box-shadow: -2px 0 0 0 #0ea5e9 inset; }
.rdfop-tabs--left .rdfop-tabs__tab--dragover-before, .rdfop-tabs--right .rdfop-tabs__tab--dragover-before, .rdfop-tabs--leftRotated .rdfop-tabs__tab--dragover-before, .rdfop-tabs--rightRotated .rdfop-tabs__tab--dragover-before { box-shadow: 0 2px 0 0 #0ea5e9 inset; }
.rdfop-tabs--left .rdfop-tabs__tab--dragover-after, .rdfop-tabs--right .rdfop-tabs__tab--dragover-after, .rdfop-tabs--leftRotated .rdfop-tabs__tab--dragover-after, .rdfop-tabs--rightRotated .rdfop-tabs__tab--dragover-after { box-shadow: 0 -2px 0 0 #0ea5e9 inset; }
.rdfop-tabs__close { display: none; background: none; border: none; cursor: pointer; font-size: 12px; color: var(--muted); padding: 0 2px; line-height: 1; }
.rdfop-tabs__tab:hover .rdfop-tabs__close { display: inline; }
.rdfop-tabs__close:hover { color: #ef4444; }
.rdfop-tabs__dir { padding: 8px 8px; cursor: pointer; background: none; border: none; font-size: 14px; color: var(--muted); line-height: 1; }
.rdfop-tabs__dir:hover { color: var(--text); }
.rdfop-tabs__add { padding: 8px 12px; cursor: pointer; background: none; border: none; font-size: 16px; color: var(--muted); }
.rdfop-tabs__add:hover { color: var(--text); }
.rdfop-tabs__content { flex: 1; overflow: hidden; position: relative; }
.rdfop-tabs__panel { display: none; position: absolute; inset: 0; overflow: auto; }
.rdfop-tabs__panel--active { display: block; }""" ;
  rdfop:componentTemplate """@PREFIX rdfop: <https://launix.de/rdfop/schema#> .
PARAMETER ?id "id"
SELECT ?dir WHERE { ?id rdfop:tabDirection ?dir }
BEGIN
?><div class='rdfop-c rdfop-tabs rdfop-tabs--<?rdf PRINT HTML ?dir ?>' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?id ?>}' data-rdfop-dir='<?rdf PRINT HTML ?dir ?>'>
  <div class='rdfop-tabs__bar'>
    <button class='rdfop-tabs__dir' onclick='rdfopTabDirection(this.closest(&quot;.rdfop-tabs__bar&quot;))'>&#x2B82;</button>
    <?rdf
    SELECT ?tab, ?label, ?ord WHERE { ?tab rdfop:order ?ord . ?tab rdfop:parent ?id . ?tab a rdfop:Tab . ?tab rdfop:tabLabel ?label } ORDER BY ?ord
    BEGIN
    ?><div class='rdfop-tabs__tab' data-tab-id='<?rdf PRINT HTML ?tab ?>' data-tab-order='<?rdf PRINT HTML ?ord ?>' draggable='true' ondragstart='rdfopTabDragStart(event)' ondragover='rdfopTabDragOver(event)' ondragleave='rdfopTabDragLeave(event)' ondrop='rdfopTabDrop(event)' ondragend='rdfopTabDragEnd(event)' onclick='(function(t){var tabs=t.closest(&quot;.rdfop-tabs&quot;);tabs.querySelectorAll(&quot;.rdfop-tabs__tab&quot;).forEach(function(x){x.classList.remove(&quot;rdfop-tabs__tab--active&quot;)});tabs.querySelectorAll(&quot;.rdfop-tabs__panel&quot;).forEach(function(x){x.classList.remove(&quot;rdfop-tabs__panel--active&quot;)});t.classList.add(&quot;rdfop-tabs__tab--active&quot;);var p=tabs.querySelector(&quot;.rdfop-tabs__panel[data-tab-id=\x27&quot;+t.dataset.tabId+&quot;\x27]&quot;);if(p)p.classList.add(&quot;rdfop-tabs__panel--active&quot;)})(this)'>
      <span class='rdfop-c rdfop-textedit' data-rdfop-params='{&quot;id&quot;:<?rdf PRINT JSON ?tab ?>,&quot;p&quot;:&quot;https://launix.de/rdfop/schema#tabLabel&quot;}' ondblclick='event.stopPropagation();rdfopSwap(this,&quot;edit&quot;)'><?rdf PRINT HTML ?label ?></span>
      <button class='rdfop-tabs__close' onclick='event.stopPropagation();rdfopDelete(this.closest(&quot;.rdfop-tabs__tab&quot;))'>&#x2715;</button>
    </div><?rdf
    END
    ?>
    <button class='rdfop-tabs__add' onclick='rdfopCreate(this,&quot;<?rdf PRINT HTML ?id ?>&quot;,&quot;https://launix.de/rdfop/schema#Tab&quot;)'>+</button>
  </div>
  <div class='rdfop-tabs__content'>
    <?rdf
    SELECT ?tab, ?child, ?ord WHERE { ?tab rdfop:order ?ord . ?tab rdfop:parent ?id . ?tab a rdfop:Tab . ?tab rdfop:children ?child } ORDER BY ?ord
    BEGIN
    ?><div class='rdfop-tabs__panel' data-tab-id='<?rdf PRINT HTML ?tab ?>'><?rdf CALL render_object(?child, REQ, RES) ?></div><?rdf
    END
    ?>
  </div>
</div>
<?rdf
END""" .

